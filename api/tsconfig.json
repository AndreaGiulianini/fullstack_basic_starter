{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "paths": {
      "@/*": ["./*"],
      "@middleware/*": ["./middleware/*"],
      "@models/*": ["./models/*"],
      "@routes/*": ["./routes/*"],
      "@types/*": ["./types/*"],
      "@utils/*": ["./utils/*"]
    }
  },
  "watchOptions": {
    "watchFile": "dynamicPriorityPolling"
  },
  "include": ["**/*.ts", "app.ts", "routes/betterAuthRoutes.ts"],
  "exclude": ["node_modules"]
}
